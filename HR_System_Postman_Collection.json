						"method": "POST",
						"header": [
							{
								"key": "x-tenant-slug",
								"value": "{{tenant_slug}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"qrToken\": \"{{static_qr_token}}\",\n    \"location\": {\n        \"lat\": 30.104099,\n        \"lng\": 31.3248849\n    }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/attendance/check-in",
							"host": [
