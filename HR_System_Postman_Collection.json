							],
							"path": [
								"attendance",
								"check-in"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "4. Payroll",
			"item": [
				{
					"name": "Generate Monthly Slip",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "x-tenant-slug",
								"value": "{{tenant_slug}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"employeeId\": \"{{employee_id}}\",\n    \"month\": 5,\n    \"year\": 2026\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/payroll/generate",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"payroll",
								"generate"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000/api/v1",
			"type": "string"
		},
		{
			"key": "tenant_slug",
			"value": "fairdirection",
			"type": "string"
		},
		{
			"key": "employee_id",
			"value": "PASTE_ID_HERE",
			"type": "string"
		},
		{
			"key": "static_qr_token",
